# --- Database (Postgres) ---
# `docker compose -f docker-compose.dev.yml up -d` starts a matching local Postgres.
DATABASE_URL="postgres://bookclub:bookclub@localhost:5432/bookclub"

# --- Auth.js ---
# Generate one with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET="dev-secret-change-me"
# Trust the local host in dev; set to your real URL in prod.
AUTH_URL="http://localhost:3000"

# --- Magic-link email delivery ---
# In development, leave RESEND_API_KEY unset: the magic-link URL is printed to the
# server console so you can sign in without any email provider.
# In production, set a Resend API key and a verified from-address.
# RESEND_API_KEY=""
EMAIL_FROM="Book Club <no-reply@bookclub.local>"

# --- Seed (npm run db:seed) ---
# Comma-separated emails to add as members of the seeded group. First one is owner.
SEED_GROUP_NAME="The Book Club"
SEED_MEMBER_EMAILS="you@example.com"
