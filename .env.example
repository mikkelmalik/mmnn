# ============================================================================
# Book Club — single configuration file for Docker Compose.
#
#   cp .env.example .env    # then edit the values below
#   docker compose up -d --build
#
# This one file drives every service and both run modes. Copy it to `.env`
# (Docker Compose reads `.env` automatically) and edit.
# ============================================================================

# --- Run mode (this is the one switch) --------------------------------------
# dev          → app runs with hot reload on http://localhost:3000
# prod         → built app on http://localhost:3000 (no domain / behind your own proxy)
# prod,proxy   → built app + Caddy automatic HTTPS for DOMAIN (hosted production)
COMPOSE_PROFILES=dev

# --- Database (Postgres container) ------------------------------------------
POSTGRES_USER=bookclub
POSTGRES_PASSWORD=change-me-too
POSTGRES_DB=bookclub
# DATABASE_URL is derived automatically inside the containers (points at the
# `db` service). Only override DB_PORT if 5432 is taken on the host.
# DB_PORT=5432

# --- App / Auth.js ----------------------------------------------------------
# Host port the app is published on (ignored for HTTPS, where Caddy uses 80/443).
APP_PORT=3000
# Generate a real one with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="dev-secret-change-me"
# Public URL. dev: http://localhost:3000 — hosted prod: https://your-domain
AUTH_URL="http://localhost:3000"

# --- Hosted HTTPS (only used with the `proxy` profile) ----------------------
# Point this domain's A record at the server; Caddy fetches a Let's Encrypt cert.
# Also set AUTH_URL above to https://this-domain.
DOMAIN="example.com"

# --- Initial admin (group owner) --------------------------------------------
# Created on first run; re-seeding re-syncs the password, so change it here to
# rotate it. Sign in with these at /login.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me-please"
ADMIN_NAME="Admin"

# --- Magic-link email delivery (optional) -----------------------------------
# Leave RESEND_API_KEY unset for dev: the magic-link URL is printed to the app
# container log so you can sign in without any email provider. In production,
# set a Resend API key and a verified from-address to actually send the email.
# RESEND_API_KEY=""
EMAIL_FROM="Book Club <no-reply@bookclub.local>"

# --- Seed (optional) --------------------------------------------------------
SEED_GROUP_NAME="The Book Club"
# Extra members to pre-create (comma-separated). These have no password and would
# sign in via magic link; usually you just invite people with a link instead.
SEED_MEMBER_EMAILS=""
